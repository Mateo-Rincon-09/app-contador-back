generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  lastName  String?
  email     String   @unique
  password  String
  confirmPassword String
  createdAt DateTime @default(now())

  movimientos Movimiento[]
  savings Saving[]
}

model Movimiento {
  id           String   @id @default(uuid())
  montoIngreso Float?
  montoGasto   Float?
  categoria    String
  descripcion  String
  fecha        DateTime

  userId String
  user   User   @relation(fields: [userId], references: [id])
}

model Saving {
  id String @id @default(ulid())
  montoMeta Float?
  progreso Float?

  userId String
  user User @relation(fields: [userId], references: [id])
}
