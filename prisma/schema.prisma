generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TransactionType {
  income
  expense
  saving
}

 enum SavingType {
  active
  closed
  deleted
}

model user {
  id          String   @id @default(uuid())
  name        String
  lastName    String?
  email       String   @unique
  password    String
  dateCreated DateTime @default(now())

  transactions transaction[]
  saving       saving[]
  categories   category[]
}

model transaction {
  id          String          @id @default(uuid())
  amount      Float
  description String
  dateCreated DateTime        @default(now())
  dateUpdated DateTime
  type        TransactionType @default(expense)

  //Relations
  userId String
  user   user   @relation(fields: [userId], references: [id])

  categoryId String
  category   category @relation(fields: [categoryId], references: [id])

  savingId String?
  saving   saving? @relation(fields: [savingId], references: [id])
}

model category {
  id   String @id @default(uuid())
  name String

  //Relations
  transactions transaction[]

  userId String
  user   user   @relation(fields: [userId], references: [id])
}

model saving {
  id             String     @id @default(uuid())
  amount         Float
  amountProgress Float?
  dateCreated    DateTime   @default(now())
  dateUpdated    DateTime?
  dateStart      DateTime
  dateEnd        DateTime
  status         SavingType @default(active)

  //Relations
  transactions transaction[]

  userId String
  user   user   @relation(fields: [userId], references: [id])
}
