generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  lastName  String?
  password  String
  createdAt DateTime @default(now())

  movimientos Movimiento[]
}

model Movimiento {
  id           String @id @default(uuid())
  montoIngreso Float?
  montoGasto   Float?
  categoria    String
  descripcion  String
  fecha        DateTime 

  userId String
  user User @relation(fields: [userId], references: [id])
}
